rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return isSignedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function userOrg() {
      return hasUserDoc() ? userData().orgId : null;
    }

    function userRole() {
      return hasUserDoc() ? userData().role : null;
    }

    function isInOrg(orgId) {
      return hasUserDoc() && userOrg() == orgId;
    }

    function isOwner(orgId) {
      return isInOrg(orgId) &&
        (userRole() == 'OWNER' || userRole() == 'owner');
    }

    function isMember(orgId) {
      return isInOrg(orgId) &&
        (
          userRole() == 'OWNER' ||
          userRole() == 'owner' ||
          userRole() == 'MEMBER' ||
          userRole() == 'member'
        );
    }

    match /tasks/{taskId} {
      allow read: if isMember(resource.data.orgId);
      allow create: if isMember(request.resource.data.orgId);
      allow update: if isMember(resource.data.orgId);
      allow delete: if isMember(resource.data.orgId);
    }

    match /projects/{projectId} {
      allow read: if isMember(resource.data.orgId);
      allow create: if isMember(request.resource.data.orgId);
      allow update: if isOwner(resource.data.orgId);
      allow delete: if isOwner(resource.data.orgId);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    match /organizations/{orgId} {
      allow read: if isInOrg(orgId);
      allow create: if isSignedIn();
      allow update: if isOwner(orgId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}